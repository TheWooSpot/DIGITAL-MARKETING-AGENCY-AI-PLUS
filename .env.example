# Twilio MCP (Cursor: set TWILIO_MCP_CREDENTIALS in OS env or MCP env — not used by Vite at build time)
# MCP loads: core API (SMS/calls/numbers), Messaging API, Phone Numbers v2 — configured on the Twilio MCP server in Cursor
# Create API Key + Secret: https://www.twilio.com/docs/iam/api-keys
# Format: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx/SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx:your_api_secret
# TWILIO_MCP_CREDENTIALS=

# Checkout (Stripe — future session)
VITE_CHECKOUT_VARIANT_OVERRIDE=
