# Vapi AI - Get your public key from https://dashboard.vapi.ai/ (Profile > API Keys)
# The public key is safe to use in client-side code.
VITE_VAPI_PUBLIC_KEY=309aa6c0-cf6f-4e24-b30d-9d7646c58939

# Optional: host the URL diagnostic on another origin (default = same Vite app at /doors/url-diagnostic).
# VITE_ANYDOOR_ORIGIN=https://example.com

# Shared reports (/report/:token) — Supabase anon key + URL (embedded at build time on Vercel).
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional canonical origin for share links when window is unavailable (SSR/build).
# VITE_SITE_URL=https://socialutely-any-door-engine.vercel.app
