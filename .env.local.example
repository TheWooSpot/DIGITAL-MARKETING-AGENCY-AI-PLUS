# Vite app (platform home + AnyDoor) — copy to .env.local locally; mirror on Vercel.
# Only names starting with VITE_ are injected into the client bundle (via vite.config.ts define).

# Optional: call Edge Function directly instead of same-origin /api/prospect-diagnostic
# VITE_DIAGNOSTIC_URL=https://YOUR_PROJECT.supabase.co/functions/v1/prospect-diagnostic

# Shared reports (/report/:token) — both required in production or lookups always fail
VITE_SUPABASE_URL=https://aagggflwhadxjjhcaohc.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: canonical site for share links when window is unavailable
# VITE_SITE_URL=https://socialutely-any-door-engine.vercel.app

# Internal /team/tiers gate (exposed in client bundle — use only as a light team screen)
# VITE_TEAM_PASSWORD=socialutely2026

# This repo is Vite-only (no Next.js /app).

# --- Vercel server only (for api/report-by-token.ts) — never VITE_* ---
# Same project as above; used by the serverless function to read layer5_prospects with service role.
# SUPABASE_URL=https://aagggflwhadxjjhcaohc.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
