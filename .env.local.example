# Any Door Engine — Next.js app
# Copy to .env.local and fill in if you need overrides.

# Supabase — required for shared report pages (/report/[token])
# Dashboard → Settings → API → copy Project URL and anon public key
NEXT_PUBLIC_SUPABASE_URL=https://aagggflwhadxjjhcaohc.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: canonical site origin for share links (defaults to window.location.origin in the browser)
# NEXT_PUBLIC_SITE_URL=https://socialutely-any-door-engine.vercel.app

# Prospect diagnostic Edge Function URL (optional override; Vercel uses this name)
# NEXT_PUBLIC_DIAGNOSTIC_URL=https://aagggflwhadxjjhcaohc.supabase.co/functions/v1/prospect-diagnostic
# NEXT_PUBLIC_PROSPECT_DIAGNOSTIC_URL=https://aagggflwhadxjjhcaohc.supabase.co/functions/v1/prospect-diagnostic
