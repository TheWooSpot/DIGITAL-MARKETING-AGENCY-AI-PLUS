# Vite app (platform home + AnyDoor at /doors/url-diagnostic)
# Copy to .env.local for local dev. On Vercel, set the same names in Project Settings.

# Preferred — exposed to client via import.meta.env.VITE_*
VITE_SUPABASE_URL=https://aagggflwhadxjjhcaohc.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: canonical site for share links when window is unavailable
# VITE_SITE_URL=https://socialutely-any-door-engine.vercel.app

# If your Vercel project still only has NEXT_PUBLIC_SUPABASE_* (from the old Next app),
# those are picked up at build time in vite.config.ts — but prefer renaming to VITE_*.

# Next.js app in /app (if you run next dev separately) — not read by Vite
# NEXT_PUBLIC_SUPABASE_URL=...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...

# Optional: diagnostic Edge Function override (Next API route only)
# NEXT_PUBLIC_DIAGNOSTIC_URL=https://aagggflwhadxjjhcaohc.supabase.co/functions/v1/prospect-diagnostic
